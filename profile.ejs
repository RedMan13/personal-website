<!DOCTYPE html>
<html>
<head>
    <%
        const user = req.query.user;
        const profile = global.users 
            ? await users.getPartialProfile(user)  
            : {
                banner: '/scratch-for-discord.png',
                picture: '/puzzlingggg.jpg',
                username: 'Joe', 
                styles: `
                    .banner {
                        width: 100%;
                        height: 96px;
                        object-fit: cover;
                    }
                    .profile-identity {
                        display: flex;
                        gap: 10px;
                        justify-content: left;
                        align-items: center;
                        margin: 0px 10px;
                        margin-top: -32px;
                    }
                    .pfp-image {
                        width: 64px;
                        border-radius: 25%;
                    }
                    .username {
                        font-size: large;
                        font-weight: bold;
                        margin-top: 32px;
                        display: inline-block;
                    }
                    .bio-text {
                        margin: 16px 7px;
                        overflow: scroll;
                        white-space: preserve;
                    }
                    .backdrop {
                        border-radius: 16px;
                        border: 1px solid #AAA;
                        background-color: white;
                    }
                `,
                bio: 'Lorem Ipsum\nDollar Sallet'
            };
        const bioFixed = escapeFn(profile.bio);
        let collector = ''
        let isCollecting = false;
        let bioWords = [['bio-text', ['']]];
        for (let i = 0; i < bioFixed.length; i++) {
            const current = bioWords.at(-1);
            if (bioFixed[i] === '\\') {
                if (isCollecting)
                    collector += bioFixed[++i];
                else
                    current[1][current[1].length -1] += bioFixed[++i];
                continue;
            }
            if (isCollecting && bioFixed[i] === '[') {
                
            }
            if (isCollecting) { collector += bioFixed[i]; continue; }
            if (bioFixed[i] !== '@') { current[1][current[1].length -1] += bioFixed[i]; continue; }
        }
    %>
</head>
<body class="backdrop">
    <img class="banner" src="<%- profile.banner %>">
    <div class="profile-identity">
        <img class="pfp-image" src="<%- profile.picture %>">
        <span class="username"><%- profile.username %></span>
    </div>
    <div class="bio-text"><%- profile.bio %></div>
    
    <script>
        const style = document.createElement('style');
        style.innerText = <%- JSON.stringify(profile.styles).replaceAll('/', '\\x2F') %>;
        document.head.appendChild(style);
    </script>
</body>
</html>