<!TEMPLATE /cardpage.html>
<head>
    <title>Sign In</title>
    <%
        const meta = new URLSearchParams(req.body?.toString?.());
        const hasSubmitted = !!req.body?.length;
        console.log(hasSubmitted);
        const loggedIn = hasSubmitted && await users.authorize(meta.get('username'), meta.get('password'));
        if (loggedIn) res.header('Set-Cookie', `username=${escape(meta.get('username'))}; password=${escape(meta.get('password'))}`);
    %>
    <style>
        p {
            margin: 0px;
            margin-top: 6px;
        }
        form { padding: 6px; }
    </style>
</head>
<body>
    <% if (!hasSubmitted) { %>
        <form method="post">
            <p>Username:</p>
            <input type="text" name="username" placeholder="John Sigma">
            <p>Password:</p>
            <input type="password" name="password"><br><br>
            <input type="submit" name="login">
        </form>
    <% } else if (!loggedIn) { %>
        <p>Oops! looks like that account info wasnt correct. Maybe you spelled something wrong? Make sure you already have an account before you try signing into it.</p>
    <% } else { %>
        <p>Logged in!</p>
    <% } %>
</body>